{
  "name": "rolltrack",
  "private": true,
  "workspaces": ["mobile", "server", "packages/*"],
  "scripts": {
    "start": "expo start ./mobile",
    "mobile": "expo start ./mobile",
    "android": "expo start ./mobile --android",
    "ios": "expo start ./mobile --ios",
    "web": "expo start ./mobile --web",
    "lint": "expo lint ./mobile",
    "server": "npm run dev -w @rolltrack/server"
  }
}
