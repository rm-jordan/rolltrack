{
  "name": "rolltrack",
  "private": true,
  "workspaces": ["mobile", "server", "packages/*"],
  "scripts": {
    "start": "npm run start -w @rolltrack/mobile",
    "start:clear": "npm run start -w @rolltrack/mobile -- --clear",
    "mobile": "npm run start -w @rolltrack/mobile",
    "android": "npm run android -w @rolltrack/mobile",
    "ios": "npm run ios -w @rolltrack/mobile",
    "web": "npm run web -w @rolltrack/mobile",
    "lint": "npm run lint -w @rolltrack/mobile",
    "server": "npm run dev -w @rolltrack/server"
  }
}
